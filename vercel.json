cat > vercel.json << 'EOF'
{
  "version": 2,
  "buildCommand": "npx vite build",
  "outputDirectory": "dist/public",
  "installCommand": "npm install --include=dev",
  "framework": null,
  "functions": {
    "api/index.ts": {
      "maxDuration": 30,
      "includeFiles": "migrations/**,server/**,shared/**"
    },
    "api/cron.ts": {
      "maxDuration": 30,
      "includeFiles": "server/**,shared/**"
    }
  },
  "rewrites": [
    { "source": "/api/cron", "destination": "/api/cron" },
    { "source": "/api/:path*", "destination": "/api/index" },
    { "source": "/:path*", "destination": "/index.html" }
  ],
  "crons": [
    { "path": "/api/cron", "schedule": "0 */6 * * *" }
  ]
}
EOF